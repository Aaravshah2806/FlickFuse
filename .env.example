# Server
ENV=development
PORT=3000

# Database
# Connects to the docker-compose postgres container by default
DATABASE_URL=postgresql://user:password@localhost:5434/streamsync
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-replace-in-production
JWT_ACCESS_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=30

# External APIs
OPENAI_API_KEY=your-openai-api-key-here
TMDB_API_KEY=your-tmdb-api-key-here
SENDGRID_API_KEY=your-sendgrid-api-key-here
FROM_EMAIL=noreply@streamsync.app
